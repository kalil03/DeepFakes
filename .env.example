# Example environment variables for DeepTrace.
# Copy this file to .env and fill in your credentials.

# Sightengine API (optional — used for cross-validation)
SIGHTENGINE_USER=your_user_id_here
SIGHTENGINE_SECRET=your_secret_here

# Set to 1 to enable Flask debug mode (NEVER in production)
FLASK_DEBUG=0

# Set to 1 if running on AMD ROCm GPU
USE_ROCM=0
